# Optional runtime toggles

# PaddleOCR may perform a connectivity check for model hosters.
# Set this to True if you want to bypass that check.
DISABLE_MODEL_SOURCE_CHECK=True

# Uvicorn
HOST=0.0.0.0
PORT=8000

# Gemini API Key for form analysis
GEMINI_API_KEY=your gemini api key

# OpenAI API Key for form image generation
OPENAI_API_KEY=your-openai-api-key
OPENAI_FORM_ANALYSIS_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-2
